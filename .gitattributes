# Handle line endings automatically for files detected as text 
# and leave binary files untouched
* text=auto

# Force LF for shell scripts and build configs
*.sh text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
